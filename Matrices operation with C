void op_addition(void) {
    printf(BOLD MAG "\n  ── MATRIX ADDITION ──────────────────────────\n" RST);
    printf(DIM "  Formula: R[i][j] = A[i][j] + B[i][j]\n" RST);
 
    int r, c;
    if (!input_dimensions("Dimensions of A and B (must be equal):", &r, &c)) return;
 
    double A[MAX][MAX], B[MAX][MAX], R[MAX][MAX];
    input_matrix("Matrix A", A, r, c);
    input_matrix("Matrix B", B, r, c);
 
    add_matrices(A, B, R, r, c);
 
    print_matrix("Matrix A", A, r, c);
    printf(BOLD "  +\n");
    print_matrix("Matrix B", B, r, c);
    printf(BOLD GRN "  = Result\n" RST);
    print_matrix("A + B", R, r, c);
 
    printf(GRN BOLD "\n  ✔ Addition complete!\n" RST);
}
 
void op_multiplication(void) {
    printf(BOLD MAG "\n  ── MATRIX MULTIPLICATION ────────────────────\n" RST);
    printf(DIM "  Formula: R[i][j] = Σ A[i][k] * B[k][j]\n" RST);
    printf(DIM "  Requirement: cols(A) == rows(B)\n" RST);
 
    int rA, cA, rB, cB;
    printf(YLW "\n  Dimensions of A:\n" RST);
    printf(CYN "  Rows: " RST); scanf("%d", &rA); flush_input();
    printf(CYN "  Cols: " RST); scanf("%d", &cA); flush_input();
 
    printf(YLW "\n  Dimensions of B:\n" RST);
    printf(CYN "  Rows: " RST); scanf("%d", &rB); flush_input();
    printf(CYN "  Cols: " RST); scanf("%d", &cB); flush_input();
 
    if (cA != rB) {
        printf(RED "\n  ✗ Incompatible! cols(A)=%d ≠ rows(B)=%d\n" RST, cA, rB);
        printf("  Press Enter..."); flush_input(); return;
    }
    if (rA<1||rA>MAX||cA<1||cA>MAX||cB<1||cB>MAX) {
        printf(RED "\n  ✗ Dimensions out of range (1-%d).\n" RST, MAX);
        printf("  Press Enter..."); flush_input(); return;
    }
 
    double A[MAX][MAX], B[MAX][MAX], R[MAX][MAX];
    input_matrix("Matrix A", A, rA, cA);
    input_matrix("Matrix B", B, rB, cB);
 
    multiply_matrices(A, B, R, rA, cA, cB);
 
    print_matrix("Matrix A", A, rA, cA);
    printf(BOLD "  ×\n");
    print_matrix("Matrix B", B, rB, cB);
    printf(BOLD GRN "  = Result [%d × %d]\n" RST, rA, cB);
    print_matrix("A × B", R, rA, cB);
 
    printf(GRN BOLD "\n  ✔ Multiplication complete!\n" RST);
}
 
void op_transpose(void) {
    printf(BOLD MAG "\n  ── MATRIX TRANSPOSE ─────────────────────────\n" RST);
    printf(DIM "  Formula: T[j][i] = A[i][j]\n" RST);
 
    int r, c;
    if (!input_dimensions("Dimensions of A:", &r, &c)) return;
 
    double A[MAX][MAX], T[MAX][MAX];
    input_matrix("Matrix A", A, r, c);
    transpose_matrix(A, T, r, c);
 
    print_matrix("Matrix A", A, r, c);
    printf(BOLD GRN "  ᵀ Result [%d × %d]\n" RST, c, r);
    print_matrix("Aᵀ (Transpose)", T, c, r);
 
    printf(GRN BOLD "\n  ✔ Transpose complete!\n" RST);
}
 
void op_scalar(void) {
    printf(BOLD MAG "\n  ── SCALAR MULTIPLICATION ────────────────────\n" RST);
    printf(DIM "  Formula: R[i][j] = k * A[i][j]\n" RST);
 
    int r, c;
    if (!input_dimensions("Dimensions of A:", &r, &c)) return;
 
    double A[MAX][MAX], R[MAX][MAX];
    input_matrix("Matrix A", A, r, c);
 
    double k;
    printf(CYN "\n  Scalar k = " RST);
    while (scanf("%lf", &k) != 1) { flush_input(); printf(RED "  Re-enter: " RST); }
    flush_input();
 
    scalar_multiply(A, R, r, c, k);
 
    print_matrix("Matrix A", A, r, c);
    printf(BOLD "  k = %.4g\n", k);
    print_matrix("k × A", R, r, c);
 
    printf(GRN BOLD "\n  ✔ Scalar multiplication complete!\n" RST);
}
 
void op_determinant(void) {
    printf(BOLD MAG "\n  ── MATRIX DETERMINANT ───────────────────────\n" RST);
    printf(DIM "  Recursive cofactor expansion\n" RST);
 
    int n;
    printf(CYN "\n  Square matrix size n (1-%d): " RST, MAX);
    if (scanf("%d", &n) != 1 || n < 1 || n > MAX) {
        flush_input(); printf(RED "  ✗ Invalid.\n" RST); return;
    }
    flush_input();
 
    double A[MAX][MAX];
    input_matrix("Matrix A", A, n, n);
 
    double det = determinant(A, n);
 
    print_matrix("Matrix A", A, n, n);
    printf(BOLD YLW "\n  det(A) = " GRN "%.6g" RST "\n", det);
 
    if (det != 0.0)
        printf(GRN "  ✔ Matrix is invertible (det ≠ 0)\n" RST);
    else
        printf(YLW "  ⚠ Matrix is singular (det = 0, not invertible)\n" RST);
}
 
void op_demo(void) {
    printf(BOLD MAG "\n  ── DEMO: SAMPLE 3×3 MATRICES ───────────────\n" RST);
 
    double A[MAX][MAX] = {
        {1, 2, 3},
        {4, 5, 6},
        {7, 8, 9}
    };
    double B[MAX][MAX] = {
        {9, 8, 7},
        {6, 5, 4},
        {3, 2, 1}
    };
    double R[MAX][MAX], T[MAX][MAX];
    int n = 3;
 
    printf(YLW "\n  Demo matrices (3×3):\n" RST);
    print_matrix("Matrix A", A, n, n);
    print_matrix("Matrix B", B, n, n);
 
    printf(BOLD "\n  1) A + B\n" RST);
    add_matrices(A, B, R, n, n);
    print_matrix("A + B", R, n, n);
 
    printf(BOLD "\n  2) A × B\n" RST);
    multiply_matrices(A, B, R, n, n, n);
    print_matrix("A × B", R, n, n);
 
    printf(BOLD "\n  3) Aᵀ\n" RST);
    transpose_matrix(A, T, n, n);
    print_matrix("Aᵀ", T, n, n);
 
    printf(BOLD "\n  4) det(A) = " GRN "%.6g" RST "\n", determinant(A, n));
    printf(BOLD "\n  5) 2 × A\n" RST);
    scalar_multiply(A, R, n, n, 2.0);
    print_matrix("2A", R, n, n);
 
    printf(GRN BOLD "\n  ✔ Demo complete!\n" RST);
}
 
