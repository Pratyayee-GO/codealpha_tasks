int main(void) {
    int choice;
 
    print_banner();
    printf("\n" DIM "  Press Enter to continue..." RST);
    flush_input();
 
    do {
        print_banner();
        print_menu();
 
        if (scanf("%d", &choice) != 1) { flush_input(); choice = -1; continue; }
        flush_input();
 
        switch (choice) {
            case 1: op_addition();       break;
            case 2: op_multiplication(); break;
            case 3: op_transpose();      break;
            case 4: op_scalar();         break;
            case 5: op_determinant();    break;
            case 6: op_demo();           break;
            case 0:
                printf(CYN BOLD "\n  👋 Exiting Matrix Operations Engine.\n\n" RST);
                break;
            default:
                printf(RED "\n  ✗ Invalid option. Choose 0–6.\n" RST);
        }
 
        if (choice != 0) {
            printf("\n" DIM "  Press Enter to return to menu..." RST);
            flush_input();
        }
 
    } while (choice != 0);
 
    return 0;
}
