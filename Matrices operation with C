/* ═══════════════════════════════════════════════════════════════
   MATRIX DISPLAY
═══════════════════════════════════════════════════════════════ */
 
void print_matrix(const char *label, double mat[MAX][MAX], int rows, int cols) {
    printf("\n" BOLD CYN "  %s" RST " [%d × %d]\n", label, rows, cols);
    printf(CYN "  ┌");
    for (int j = 0; j < cols; j++) printf("──────────");
    printf("─┐\n" RST);
 
    for (int i = 0; i < rows; i++) {
        printf(CYN "  │" RST);
        for (int j = 0; j < cols; j++) {
            double v = mat[i][j];
            if (v < 0)
                printf(RED "  %7.2f " RST, v);
            else if (v == 0)
                printf(DIM "  %7.2f " RST, v);
            else
                printf(GRN "  %7.2f " RST, v);
        }
        printf(CYN "│\n" RST);
    }
 
    printf(CYN "  └");
    for (int j = 0; j < cols; j++) printf("──────────");
    printf("─┘\n" RST);
}
 
/* ═══════════════════════════════════════════════════════════════
   INPUT
═══════════════════════════════════════════════════════════════ */
 
void input_matrix(const char *name, double mat[MAX][MAX], int rows, int cols) {
    printf(YLW "\n  Enter elements of %s [%d × %d]:\n" RST, name, rows, cols);
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            printf(CYN "  [%d][%d] = " RST, i, j);
            while (scanf("%lf", &mat[i][j]) != 1) {
                printf(RED "  ✗ Invalid. Re-enter: " RST);
                flush_input();
            }
        }
    }
    flush_input();
}
 
int input_dimensions(const char *prompt, int *r, int *c) {
    printf(YLW "\n  %s\n" RST, prompt);
    printf(CYN "  Rows (1-%d): " RST, MAX);
    if (scanf("%d", r) != 1 || *r < 1 || *r > MAX) {
        flush_input();
        printf(RED "  ✗ Invalid rows.\n" RST);
        return 0;
    }
    printf(CYN "  Cols (1-%d): " RST, MAX);
    if (scanf("%d", c) != 1 || *c < 1 || *c > MAX) {
        flush_input();
        printf(RED "  ✗ Invalid cols.\n" RST);
        return 0;
    }
    flush_input();
    return 1;
}
 
/* ═══════════════════════════════════════════════════════════════
   CORE OPERATIONS — MODULAR FUNCTIONS
═══════════════════════════════════════════════════════════════ */
 
/*
 * add_matrices()
 * Adds two matrices A and B of same dimensions.
 * Result[i][j] = A[i][j] + B[i][j]
 */
void add_matrices(double A[MAX][MAX], double B[MAX][MAX],
                  double R[MAX][MAX], int rows, int cols) {
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            R[i][j] = A[i][j] + B[i][j];
}
 
/*
 * multiply_matrices()
 * Multiplies A [rA × cA] by B [cA × cB].
 * R[i][j] = Σ A[i][k] * B[k][j]
 */
void multiply_matrices(double A[MAX][MAX], double B[MAX][MAX],
                       double R[MAX][MAX], int rA, int cA, int cB) {
    /* Zero out result */
    for (int i = 0; i < rA; i++)
        for (int j = 0; j < cB; j++)
            R[i][j] = 0.0;
 
    for (int i = 0; i < rA; i++)
        for (int j = 0; j < cB; j++)
            for (int k = 0; k < cA; k++)
                R[i][j] += A[i][k] * B[k][j];
}
 
/*
 * transpose_matrix()
 * Transposes A [rows × cols] → T [cols × rows].
 * T[j][i] = A[i][j]
 */
void transpose_matrix(double A[MAX][MAX], double T[MAX][MAX],
                      int rows, int cols) {
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            T[j][i] = A[i][j];
}
 
/*
 * scalar_multiply()
 * Multiplies every element of A by scalar k.
 */
void scalar_multiply(double A[MAX][MAX], double R[MAX][MAX],
                     int rows, int cols, double k) {
    for (int i = 0; i < rows; i++)
        for (int j = 0; j < cols; j++)
            R[i][j] = A[i][j] * k;
}
 
/*
 * determinant()
 * Computes det(A) for an n×n matrix via cofactor expansion.
 * Recursive implementation.
 */
double determinant(double A[MAX][MAX], int n) {
    if (n == 1) return A[0][0];
    if (n == 2) return A[0][0]*A[1][1] - A[0][1]*A[1][0];
 
    double det = 0.0;
    double sub[MAX][MAX];
    int sign = 1;
 
    for (int f = 0; f < n; f++) {
        /* Build sub-matrix excluding row 0 and col f */
        int si = 0;
        for (int i = 1; i < n; i++) {
            int sj = 0;
            for (int j = 0; j < n; j++) {
                if (j == f) continue;
                sub[si][sj++] = A[i][j];
            }
            si++;
        }
        det += sign * A[0][f] * determinant(sub, n - 1);
        sign = -sign;
    }
    return det;
}
 
