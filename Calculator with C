#include <stdio.h>

int main() {
  double a, b, result;
  char op;

  printf("Enter: num op num\n");
  scanf("%lf %c %lf",
         &a, &op, &b);

  switch (op) {

    case '+':
      result = a + b;
      printf("= %.4lf\n", result);
      break;

    case '-':
      result = a - b;
      printf("= %.4lf\n", result);
      break;

    case '*':
      result = a * b;
      printf("= %.4lf\n", result);
      break;

    case '/':
      if (b == 0) {
        printf("Error: div/0\n");
      } else {
        result = a / b;
        printf("= %.4lf\n",result);
      }
      break;

    default:
      printf(
        "Invalid operator\n");
  }

  return 0;
}
