#define BOLD    "\033[1m"
#define DIM     "\033[2m"
#define RED     "\033[31m"
#define GREEN   "\033[32m"
#define YELLOW  "\033[33m"
#define BLUE    "\033[34m"
#define MAGENTA "\033[35m"
#define CYAN    "\033[36m"
#define WHITE   "\033[37m"
#define BG_BLUE "\033[44m"
#define BG_CYAN "\033[46m"
 
/* ── Student Structure ──────────────────────────────────── */
typedef struct {
    int    roll_no;
    char   name[MAX_NAME];
    char   department[MAX_DEPT];
    int    semester;
    float  cgpa;
    char   phone[MAX_PHONE];
    char   email[MAX_EMAIL];
    int    year_of_admission;
} Student;
 
