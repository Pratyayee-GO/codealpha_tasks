#define MAX_NAME      60
#define MAX_DEPT      40
#define MAX_EMAIL     60
#define MAX_PHONE     16
#define MAX_STUDENTS  1000
#define VERSION       "v2.0"
 
/* ── ANSI Color Codes ───────────────────────────────────── */
