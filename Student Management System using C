void clear_screen(void) {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}
 
void flush_input(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}
 
void print_separator(const char *title, char ch, int width) {
    int title_len = (int)strlen(title);
    int pad = (width - title_len - 2) / 2;
    printf(CYAN);
    for (int i = 0; i < pad; i++) putchar(ch);
    printf(BOLD WHITE " %s " RESET CYAN, title);
    for (int i = 0; i < pad; i++) putchar(ch);
    printf(RESET "\n");
}
 
